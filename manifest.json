{
  "manifest_version": 3,
  "name": "Time Management by O'Neal",
  "version": "1.0.0",
  "description": "Local workflow timer that creates a ChatGPT-ready productivity report.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Management by O'Neal"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}